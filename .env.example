# Copiá este archivo como .env y completá los valores reales
# NUNCA subas .env a git

# Base de datos
DB_HOST=
DB_PORT=
DB_NAME=
DB_USER=
DB_PASSWORD=

# JWT — generá una clave segura con: openssl rand -hex 32
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# CORS — dominio del frontend en producción
ALLOWED_ORIGINS=http://localhost:5500,https://tu-app.netlify.app
